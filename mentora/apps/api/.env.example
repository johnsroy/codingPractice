# ─── Mentora API — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in the values for your environment.
# Every variable has a sensible default so the server boots with zero config
# (uses local storage, mock drivers, and a dev-only JWT secret).
# ──────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://mentora:mentora@localhost:5432/mentora?schema=public

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=dev-only-change-me-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# ── Storage ───────────────────────────────────────────────────────────────────
# STORAGE_DRIVER=local   (default; uses STORAGE_LOCAL_DIR)
# STORAGE_DRIVER=s3      (requires AWS_* vars below)
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage

# AWS S3 (only required when STORAGE_DRIVER=s3)
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── OCR ───────────────────────────────────────────────────────────────────────
# OCR_DRIVER=tesseract  (default; needs native Tesseract installed)
# OCR_DRIVER=textract   (AWS Textract; needs AWS_* vars above)
# OCR_DRIVER=mock       (for tests / CI)
OCR_DRIVER=tesseract

# ── LLM ───────────────────────────────────────────────────────────────────────
# LLM_DRIVER=stub       (default; no API key needed)
# LLM_DRIVER=anthropic  (requires ANTHROPIC_API_KEY)
# LLM_DRIVER=openai     (requires OPENAI_API_KEY)
LLM_DRIVER=stub
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Video ─────────────────────────────────────────────────────────────────────
# VIDEO_DRIVER=mock     (default; no real room)
# VIDEO_DRIVER=livekit  (requires LIVEKIT_* vars)
VIDEO_DRIVER=mock
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Payments ──────────────────────────────────────────────────────────────────
# PAYMENTS_DRIVER=mock    (default; no real charges)
# PAYMENTS_DRIVER=stripe  (requires STRIPE_SECRET_KEY)
PAYMENTS_DRIVER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ── Teacher Verification ──────────────────────────────────────────────────────
# VERIFICATION_DRIVER=manual          (default; admin reviews uploaded documents)
# VERIFICATION_DRIVER=stripe_identity (requires STRIPE_SECRET_KEY above)
# VERIFICATION_DRIVER=digilocker      (STUB — requires DIGILOCKER_* vars; wire to real OAuth when ready)
VERIFICATION_DRIVER=manual

# DigiLocker OAuth 2.0 placeholders (only required when VERIFICATION_DRIVER=digilocker)
# Register at https://partners.digitallocker.gov.in/ to obtain credentials.
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
DIGILOCKER_REDIRECT_URI=http://localhost:4000/api/auth/digilocker/callback

# ── Research / Web-Search ─────────────────────────────────────────────────────
# RESEARCH_DRIVER=stub      (default)
# RESEARCH_DRIVER=tavily    (requires TAVILY_API_KEY)
# RESEARCH_DRIVER=brave     (requires BRAVE_API_KEY)
# RESEARCH_DRIVER=serpapi   (requires SERPAPI_API_KEY)
RESEARCH_DRIVER=stub
TAVILY_API_KEY=
BRAVE_API_KEY=
SERPAPI_API_KEY=
RESEARCH_MAX_RESULTS=6

# ── Platform Commission ───────────────────────────────────────────────────────
PLATFORM_COMMISSION_PCT=15
PLATFORM_COMMISSION_PCT_PRO=10

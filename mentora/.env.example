# ============================================================
# Mentora environment configuration
# Copy to .env and fill in. Everything works out-of-the-box in
# "stub" mode — production providers activate when keys are set.
# ============================================================

# --- Core ---
NODE_ENV=development
API_PORT=4000
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000

# --- Database (docker compose provides this by default) ---
DATABASE_URL=postgresql://mentora:mentora@localhost:5432/mentora?schema=public

# --- Auth ---
JWT_SECRET=dev-only-change-me-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# --- Storage adapter: "local" | "s3" ---
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./storage
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- OCR adapter: "tesseract" (default, local) | "textract" | "mock" ---
# Use "mock" in CI/tests for deterministic extraction without the WASM worker.
OCR_DRIVER=tesseract

# --- LLM adapter: "stub" (default, no key needed) | "anthropic" | "openai" ---
LLM_DRIVER=stub
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Realtime video adapter: "mock" (default) | "livekit" ---
# LiveKit gives low-latency WebRTC SFU for 1:1 coaching + classrooms.
VIDEO_DRIVER=mock
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Payments adapter: "mock" (default) | "stripe" ---
PAYMENTS_DRIVER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
PLATFORM_COMMISSION_PCT=15
PLATFORM_COMMISSION_PCT_PRO=10

# --- Web (Next.js public vars) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
